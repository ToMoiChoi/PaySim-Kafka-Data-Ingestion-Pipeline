# PaySim Kafka Pipeline Configuration env

# CSV Data
CSV_PATH=data/PS_20174392719_1491204439457_log.csv

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Topic chính
KAFKA_TOPIC=payment_events_v2

# Fault Injection
DUPLICATE_RATIO=0.10

# Kafka Producer Tuning
BATCH_SIZE=65536
LINGER_MS=50
BUFFER_MEMORY=67108864

# Retry
MAX_RETRIES=10
RETRY_INTERVAL_SEC=5

# BigQuery
BQ_PROJECT_ID=ecommerce-db2025
BQ_DATASET=paysim_dw
GOOGLE_APPLICATION_CREDENTIALS=credentials/service-account.json

# GCS Temporary Bucket cho spark-bigquery-connector
# Tạo bucket trên GCS rồi điền tên vào đây (KHÔNG có gs://)
# Ví dụ: BQ_TEMP_BUCKET=my-project-spark-temp
BQ_TEMP_BUCKET=

# Reconciliation threshold (0.0 - 1.0), mặc định 90%
RECONCILE_THRESHOLD=0.90

# PostgreSQL (Primary Sink)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=paysim_dw
POSTGRES_USER=paysim
POSTGRES_PASSWORD=paysim123

# BigQuery Backup
# Thư mục lưu Parquet file cho Load Job backup
BQ_PARQUET_BACKUP_DIR=/tmp/bq_backup
